{
  "RabbitMq": {
    "Host": "localhost",
    "Port": 5672,
    "Username": "ecom_user",
    "Password": "CHANGE_ME_IN_PRODUCTION",
    "Exchange": "ecom-events",
    "Reliability": {
      "MaxRetryAttempts": 3,
      "BaseRetryDelaySeconds": 2,
      "MessageTtlMinutes": 30,
      "CircuitBreakerFailureThreshold": 5,
      "CircuitBreakerBreakDurationSeconds": 30,
      "EnableIdempotency": true,
      "IdempotencyCacheExpiryHours": 24,
      "EnableDeadLetterQueue": true,
      "EnableConnectionRecovery": true,
      "ConnectionRecoveryIntervalSeconds": 10,
      "HeartbeatIntervalSeconds": 60
    }
  },
  "Logging": {
    "LogLevel": {
      "Ecom.Shared.Infrastructure.Messaging": "Information",
      "RabbitMQ.Client": "Warning"
    }
  }
}