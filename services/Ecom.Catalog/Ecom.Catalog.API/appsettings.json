{
  "ConnectionStrings": {
    "CatalogDb": "Server=localhost\\SQLEXPRESS01;Database=Ecom_CatalogDB;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "RabbitMq": {
    "Host": "localhost",
    "Port": 5672,
    "Username": "guest",
    "Password": "guest",
    "Exchange": "ecom-events"
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Real-IP",
    "ClientIdHeader": "X-ClientId",
    "HttpStatusCode": 429,
    "GeneralRules": [
      {
        "Endpoint": "*",
        "Period": "1m",
        "Limit": 60
      },
      {
        "Endpoint": "*",
        "Period": "1h",
        "Limit": 1000
      }
    ]
  },
  "Jwt": {
    "Authority": "https://localhost:7001",
    "Audience": "ecom-clients"
  },
  "ServiceIdentity": "Catalog-Service",
  "LogRetentionDays": 30,
  "Logging": {
    "Seq": {
      "ServerUrl": "http://localhost:5341",
      "ApiKey": ""
    },
    "Elasticsearch": {
      "Enabled": false,
      "Nodes": "http://localhost:9200"
    },
    "LogLevel": { "Default": "Information" }
  },
  "AllowedHosts": "*"
}
